# Gradle
.gradle/
build/
**/build/

# Loom / ModDevGradle run directories
**/runs/
**/run/

# Generated IDE project files — machine-specific (absolute ~/.gradle cache paths).
# Regenerate locally with:  ./gradlew eclipse -Pminecraft_version=26.2
.project
.classpath
.settings/
**/.project
**/.classpath
**/.settings/
bin/
**/bin/

# Loom/Eclipse-generated launch configs — these embed ABSOLUTE machine paths
# (e.g. -Dfabric.dli.config=C:\Users\...). Never commit them; the portable run
# configs live in .vscode/launch.json (relative ${workspaceFolder} only).
*.launch
**/*.launch
**/.eclipse/

# IntelliJ
.idea/
*.iml

# Keep the committed VSCode run configs (.vscode/launch.json, tasks.json) — NOT ignored.
